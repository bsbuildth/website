rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public content collections: anyone may read; only an authenticated
    // admin may write.
    match /projects/{id}        { allow read; allow write: if request.auth != null; }
    match /reviews/{id}         { allow read; allow write: if request.auth != null; }
    match /calculator_types/{id}{ allow read; allow write: if request.auth != null; }
    match /services/{id}        { allow read; allow write: if request.auth != null; }
    match /business_info/{id}   { allow read; allow write: if request.auth != null; }
    match /content/{id}         { allow read; allow write: if request.auth != null; }
    match /settings/{id}        { allow read; allow write: if request.auth != null; }
    match /references/{id}      { allow read; allow write: if request.auth != null; }
    match /menus/{id}           { allow read; allow write: if request.auth != null; }
    match /images/{id}          { allow read; allow write: if request.auth != null; }

    // Contact submissions: anyone may create (with basic field validation),
    // but only an authenticated admin may read / update / delete.
    match /contacts/{id} {
      allow create: if request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.contact_info is string
                    && request.resource.data.contact_info.size() > 0;
      allow read, update, delete: if request.auth != null;
    }
  }
}
