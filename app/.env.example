# Firebase web app config — copy to app/.env and fill with your project's values
# (Firebase Console → Project settings → Your apps → Web app → SDK config).
# These values are injected at build time (Vite reads VITE_* vars).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Used only by the one-time seed script (node src/firebase/seed.js).
# This is the admin user you created in Firebase Console → Authentication.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Optional: Google Apps Script URL for emailing on new contact submissions
# (already deployed). Leave as-is to keep email notifications working.
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbzovEiAdV-eG79hKvMAtXTZZGClcwn__bzHuXmAKyndf8Jx0rAaqhfTPPCUSRu6EtY/exec
